<!doctype html>
<html lang="pt-BR">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Quizzes</title>
  <link href="/vendor/bootstrap/bootstrap.min.css?v=<%= assetVersion %>" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css?v=<%= assetVersion %>" />
</head>

<body>
  <main class="container py-5">

    <!-- Hero -->
    <div class="text-center mb-5">
      <div class="mb-3" style="font-size:3rem">📚</div>
      <h1 class="fw-bold mb-2">Quiz de Estruturas de Dados</h1>
      <p class="text-secondary fs-5 mb-0">Teste seus conhecimentos e veja seu placar em tempo real.</p>
    </div>

    <!-- Cards -->
    <div class="row g-4 justify-content-center">
      <div class="col-12 col-md-5">
        <div class="card home-card shadow border-0 h-100" style="animation-delay:0s">
          <div class="card-body d-flex flex-column p-4">
            <div class="d-flex align-items-center gap-2 mb-3">
              <span style="font-size:2rem">🗂️</span>
              <div class="d-flex gap-2">
                <span class="badge text-bg-primary">Sim / Não</span>
                <span class="badge text-bg-secondary" id="meta-count">...</span>
              </div>
            </div>
            <h2 class="h5 fw-semibold mb-2">Estrutura de Dados</h2>
            <p class="text-secondary mb-2">Responda Sim ou Não, receba explicação imediata e acompanhe seu placar.</p>
            <ul class="text-secondary small mb-4 ps-3" style="line-height:1.8">
              <li>Complexidade assintótica e Big O</li>
              <li>Arrays, listas dinâmicas e encadeadas</li>
              <li>Pilhas, filas, deques e listas circulares</li>
              <li>Algoritmos de ordenação</li>
              <li>Busca binária, ABB/BST e percursos</li>
              <li>Hash, dicionários e sets</li>
            </ul>
            <a class="btn btn-primary w-100 mt-auto" href="/simnao">Começar quiz</a>
          </div>
        </div>
      </div>

      <div class="col-12 col-md-5">
        <div class="card home-card shadow border-0 h-100" style="animation-delay:0.15s">
          <div class="card-body d-flex flex-column p-4">
            <div class="d-flex align-items-center gap-2 mb-3">
              <span style="font-size:2rem">⏱️</span>
              <div class="d-flex gap-2">
                <span class="badge text-bg-warning text-dark">Múltipla escolha</span>
                <span class="badge text-bg-secondary" id="code-meta-count">...</span>
              </div>
            </div>
            <h2 class="h5 fw-semibold mb-2">Complexidade de Código</h2>
            <p class="text-secondary mb-4">Escolha a notação Big-O correta para cada trecho de código.</p>
            <a class="btn btn-primary w-100 mt-auto" href="/codigo">Começar quiz</a>
          </div>
        </div>
      </div>
    </div>

  </main>

  <!-- Player fixo no canto superior direito -->
  <div id="sc-player" style="
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    width: 300px;
    background: rgba(255,255,255,0.97);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    padding: 0.5rem 0.75rem 0.4rem;
    z-index: 1050;
  ">
    <div class="d-flex justify-content-between align-items-center mb-1">
      <p class="text-secondary mb-0" style="font-size:0.7rem;letter-spacing:.03em">🎵 TRILHA SONORA DO QUIZ</p>
      <button onclick="document.getElementById('sc-player').style.display='none'"
        style="background:none;border:none;font-size:1rem;cursor:pointer;color:#999;line-height:1;padding:0"
        aria-label="Fechar player">×</button>
    </div>
    <iframe width="100%" height="80" scrolling="no" frameborder="no" allow="autoplay"
      src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/cairo-aparecido-campos/se-liga-na-complexidade&color=%230d6efd&auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false&show_teaser=false&visual=false"
      style="border-radius:8px"></iframe>
  </div>

  <footer class="text-center text-secondary py-4" style="font-size:0.8rem">
    &copy; <span id="footer-year"></span> by Cairo Ap. Campos. Todos os direitos reservados.
    <script>document.getElementById('footer-year').textContent = new Date().getFullYear();</script>
  </footer>

  <script src="/vendor/bootstrap/bootstrap.bundle.min.js?v=<%= assetVersion %>"></script>
  <script>
    fetch('/api/meta').then(r => r.json()).then(d => {
      if (d.ok) document.getElementById('meta-count').textContent = d.count + ' questões';
    }).catch(() => { document.getElementById('meta-count').textContent = ''; });
    fetch('/api/code/meta').then(r => r.json()).then(d => {
      if (d.ok) document.getElementById('code-meta-count').textContent = d.count + ' questões';
    }).catch(() => { document.getElementById('code-meta-count').textContent = ''; });
  </script>
</body>

</html>