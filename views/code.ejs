<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title><%= title %></title>
    <link href="/vendor/bootstrap/bootstrap.min.css?v=<%= assetVersion %>" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <main class="container py-4 py-md-5">
      <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-between gap-2 mb-3">
        <div>
          <div class="d-flex align-items-center gap-2">
            <a class="text-decoration-none small" href="/">← voltar</a>
          </div>
          <h1 class="h3 mb-1"><%= title %></h1>
          <div class="text-secondary small" id="meta"></div>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center justify-content-end">
          <span class="badge text-bg-secondary" id="progress">—</span>
          <span class="badge text-bg-success" id="hits">Acertos: 0</span>
          <span class="badge text-bg-danger" id="misses">Erros: 0</span>
          <span class="badge text-bg-warning" id="skips">Pulos: 0</span>
          <span class="badge text-bg-dark" id="timerBadge" hidden>⏱ 00:00</span>
        </div>
      </div>

      <section class="card shadow-sm border-0" id="card">
        <div class="card-body p-3 p-md-4">
          <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
            <div class="w-100">
              <div class="progress" style="height: 10px" role="progressbar" aria-label="Progresso">
                <div class="progress-bar" id="progressBar" style="width: 0%"></div>
              </div>
            </div>
            <div class="text-secondary small text-nowrap" id="progressText">—</div>
          </div>

          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
            <div class="d-flex flex-wrap align-items-center gap-3">
              <div class="form-check form-switch m-0 align-self-end pb-1">
                <input class="form-check-input" type="checkbox" role="switch" id="randomToggle" checked />
                <label class="form-check-label" for="randomToggle">Ordem aleatória</label>
              </div>

              <div class="form-check form-switch m-0 align-self-end pb-1">
                <input class="form-check-input" type="checkbox" role="switch" id="complexityOrderToggle" />
                <label class="form-check-label" for="complexityOrderToggle">Ordem por complexidade</label>
              </div>

              <div class="form-check form-switch m-0 align-self-end pb-1">
                <input class="form-check-input" type="checkbox" role="switch" id="timerToggle" />
                <label class="form-check-label" for="timerToggle">Mostrar timer</label>
              </div>
            </div>
          </div>

          <div class="text-secondary fw-semibold mb-2" id="qtitle">Pronto?</div>
          <div class="fs-5 lh-base" id="qtext">Clique em “Começar” para iniciar.</div>

          <pre class="mt-3 mb-0 p-3 rounded border bg-light" id="codeBox" hidden></pre>

          <div class="mt-3 p-3 rounded border bg-white" id="choices" hidden></div>

          <div class="d-flex flex-wrap gap-2 mt-4" id="actions">
            <button class="btn btn-primary px-4" id="startBtn">Começar</button>
          </div>

          <div class="mt-4" id="feedback" hidden>
            <div class="alert mb-3" role="alert" id="result"></div>
            <div class="text-secondary">
              <div class="fw-semibold mb-1">Explicação</div>
              <p class="mb-0" id="explainText"></p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script src="/code.js?v=<%= assetVersion %>" type="module"></script>
    <script src="/vendor/bootstrap/bootstrap.bundle.min.js?v=<%= assetVersion %>"></script>
  </body>
</html>
